<mujoco model="plate">

    <default>
        <default class="collision">
            <geom group="3" rgba=".2 .6 .2 .3" friction="0.7 0.01 0.005"/>
        </default>
    </default>

    <asset>
        <mesh name="plate_mesh" file="meshes/plate/plate.stl"/>
        <material name="color_plate" rgba="0.6 0.6 0.6 1" specular="0.8" shininess="1.0" reflectance="0.5"/>
    </asset>

    <worldbody>
        <body name="plate_base" pos="0 0 0">
            <inertial pos="0 0 0" mass="0.1" diaginertia="0.001 0.001 0.001"/>

            <geom type="mesh" mesh="plate_mesh" material="color_plate" contype="0" conaffinity="0"/>

            <geom class="collision" type="box" mesh="plate_mesh" solref="0.01 1"/>
        </body>
    </worldbody>

</mujoco>